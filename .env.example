# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/github_pipeline

# Redis (required for job queue)
REDIS_URL=redis://localhost:6379

# Or use Upstash REST API instead of REDIS_URL
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# GitHub tokens (at least one required)
# Option 1: Comma-separated list
GITHUB_TOKENS=ghp_token1,ghp_token2,ghp_token3

# Option 2: Individual tokens
# GITHUB_TOKEN_1=ghp_...
# GITHUB_TOKEN_2=ghp_...
# GITHUB_TOKEN_3=ghp_...
# GITHUB_TOKEN_4=ghp_...
# GITHUB_TOKEN_5=ghp_...

# Environment
NODE_ENV=development
